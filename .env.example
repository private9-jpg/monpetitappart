# PostgreSQL / Prisma
POSTGRES_USER=monpetitappart
POSTGRES_PASSWORD=monpetitappart
POSTGRES_DB=monpetitappart_dev
DATABASE_URL=postgresql://monpetitappart:monpetitappart@localhost:5432/monpetitappart_dev?schema=public
DIRECT_URL=postgresql://monpetitappart:monpetitappart@localhost:5432/monpetitappart_dev

# Payload CMS
PAYLOAD_SECRET=replace-with-secure-random-value
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001

# Next.js secret for server-side features
NEXTAUTH_SECRET=replace-with-secure-random-value

# Cloudflare Turnstile
TURNSTILE_SECRET_KEY=replace-with-turnstile-secret
NEXT_PUBLIC_TURNSTILE_SITE_KEY=replace-with-turnstile-site-key

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend
RESEND_API_KEY=

# Notifications
NOTIFICATION_EMAIL=admin@monpetitappart.fr
